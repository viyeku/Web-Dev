# --- Скомпилированные файлы (Build output) ---
/dist
/tmp
/out-tsc
/bazel-out

# --- Зависимости (Dependencies) ---
# Игнорируем всю папку с библиотеками
node_modules/

# --- Логи и временные файлы (Logs) ---
npm-debug.log*
yarn-debug.log*
yarn-error.log*
logs
*.log

# --- Кэш Angular и инструментов ---
.angular/
.cache/
.sass-cache/

# --- Тестирование (Testing) ---
/coverage
/reports
testem.log
__screenshots__/

# --- Настройки IDE и редакторов ---
.idea/
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace
.history/*

# VS Code
# Сохраняем общие настройки проекта, но скрываем персональные данные
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
!.vscode/mcp.json

# --- Виртуальные окружения (Python/Other) ---
venv/
ENV/
env/
# Если используешь Poetry или другие инструменты
.venv/

# --- Системные файлы ---
.DS_Store
Thumbs.db