    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const data = pm.response.json();",
                  "  pm.collectionVariables.set('access_token', data.access);",
                  "  pm.collectionVariables.set('refresh_token', data.refresh);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"postman_seller\",\n  \"email\": \"postman@example.com\",\n  \"first_name\": \"Postman\",\n  \"last_name\": \"Seller\",\n  \"password\": \"12345\",\n  \"role\": \"seller\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/register/",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "register",
                ""
              ]
            }
          },
          "response": [
            {
              "name": "201 Created",
              "status": "Created",
              "code": 201,
              "body": "{\n  \"access\": \"<jwt access token>\",\n  \"refresh\": \"<jwt refresh token>\",\n  \"user\": {\n    \"id\": 10,\n    \"username\": \"postman_seller\",\n    \"email\": \"postman@example.com\",\n    \"first_name\": \"Postman\",\n    \"last_name\": \"Seller\",\n    \"full_name\": \"Postman Seller\",\n    \"role\": \"seller\",\n    \"can_sell\": true,\n    \"date_joined\": \"2026-04-20T12:00:00Z\"\n  }\n}"
            },
            {
              "name": "400 Validation Error",
              "status": "Bad Request",
              "code": 400,
              "body": "{\n  \"username\": [\n    \"Пользователь с таким логином уже существует.\"\n  ]\n}"
            }
          ]
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const data = pm.response.json();",
                  "  pm.collectionVariables.set('access_token', data.access);",
                  "  pm.collectionVariables.set('refresh_token', data.refresh);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"tulki\",\n  \"password\": \"12345\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/login/",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "login",
                ""
              ]
            }
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"refresh\": \"<jwt refresh token>\",\n  \"access\": \"<jwt access token>\"\n}"
            },
            {
              "name": "401 Unauthorized",
              "status": "Unauthorized",
              "code": 401,
              "body": "{\n  \"detail\": \"No active account found with the given credentials\"\n}"
            }
          ]
        },
        {
          "name": "Refresh Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  pm.collectionVariables.set('access_token', pm.response.json().access);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh\": \"{{refresh_token}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/token/refresh/",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "token",
                "refresh",
                ""
              ]
            }
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"access\": \"<new jwt access token>\"\n}"
            }
          ]
        },
